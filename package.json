{
  "name": "yardwatch",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "dev": "concurrently -n web,api -c blue,green \"pnpm --filter web run dev\" \"pnpm --filter @workspace/api run dev\"",
    "drizzle-kit:generate": "pnpm --filter @workspace/db run drizzle:generate",
    "drizzle-kit:migrate": "pnpm --filter @workspace/db run drizzle:migrate",
    "lint": "pnpm -r --if-present run lint",
    "format": "pnpm -r --if-present run format",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
